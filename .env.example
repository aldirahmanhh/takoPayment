# ========== Discord Bot ==========
DISCORD_TOKEN=your_discord_bot_token

# ========== Tako Webhook ==========
# Discord channel ID tempat Tako webhook posting
TAKO_WEBHOOK_CHANNEL_ID=your_channel_id
# (Opsional) Discord user/webhook ID milik Tako, untuk whitelist
TAKO_WEBHOOK_AUTHOR_ID=

# ========== Backend API ==========
PORT=3000
JWT_SECRET=change-me-to-random-string
INTERNAL_API_KEY=change-me-to-another-random-string

# ========== Tako ==========
TAKO_CREATOR_USERNAME=anrizz
TAKO_URL=https://tako.id/anrizz

# ========== Order ==========
ORDER_EXPIRY_MINUTES=15

# ========== Database ==========
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bot_payment?schema=public"
